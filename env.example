# Supabase Configuration (Auth + profiles)
# Copy this file to .env and fill in your actual values.
# See SUPABASE_SETUP.md for creating the project and running the profiles migration.

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe + API (create-checkout-session + webhook). See docs/STRIPE_VERCEL.md.
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_PRICE_ID_MONTHLY=price_...   (from Stripe Dashboard → Product → Pricing)
# STRIPE_PRICE_ID_YEARLY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...    (after adding webhook endpoint in Stripe)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_... (optional; for client if needed)

# Supabase (for webhook and cancel-subscription API). Backend only.
# SUPABASE_URL=same as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (from Supabase Dashboard → Settings → API → service_role)
# SUPABASE_ANON_KEY=same as VITE_SUPABASE_ANON_KEY (needed for cancel-subscription to verify user JWT)